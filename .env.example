# Vaquill backend API base (no trailing slash)
VITE_API_BASE=https://api.vaquill.ai

# Supabase project (same project the web app uses)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The origin this add-in is served from. Used to build the PKCE redirect URL.
# Local dev: https://localhost:3000  Prod: https://word.vaquill.ai
VITE_ADDIN_ORIGIN=https://localhost:3000
