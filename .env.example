# Local development env for the Vaquill Word add-in.
#
# Only the Supabase project identifier lives here. Everything else is derived:
#   - the API base is chosen by build mode (localhost in dev, api.vaquill.ai in
#     prod) in src/config.ts
#   - the add-in origin is read from window.location.origin at runtime
#
# The anon key is PUBLIC by design (Row Level Security protects the data); it is
# safe in a client bundle. NEVER put the Supabase service_role key here.
#
# In production these two values are passed as Docker build args, not committed
# (see DEPLOY.md).

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
